{
  "info": {
    "_postman_id": "capstone-event-booking-api",
    "name": "Capstone Event Booking API",
    "description": "Postman collection for testing the Event Booking API with JWT authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user account"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate user and receive JWT token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Protected Endpoints (Requires JWT)",
      "item": [
        {
          "name": "Get Current User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Get profile of currently authenticated user"
          },
          "response": []
        },
        {
          "name": "Get All Users (Admin Only)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Get all users (requires ADMIN role)"
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Get user by ID"
          },
          "response": []
        },
        {
          "name": "Create Ticket Sale",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"ticketId\": 1,\n  \"quantity\": 2,\n  \"totalPrice\": 50.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tickets-sold",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets-sold"]
            },
            "description": "Create a new ticket sale record"
          },
          "response": []
        },
        {
          "name": "Get Ticket Sales by User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tickets-sold/user/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets-sold", "user", "1"]
            },
            "description": "Get all ticket sales for a specific user"
          },
          "response": []
        },
        {
          "name": "Get Ticket Sale by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tickets-sold/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets-sold", "1"]
            },
            "description": "Get ticket sale by ID"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Public Endpoints",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/events",
              "host": ["{{baseUrl}}"],
              "path": ["api", "events"]
            },
            "description": "Get all events (public endpoint)"
          },
          "response": []
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/events/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "events", "1"]
            },
            "description": "Get event by ID (public endpoint)"
          },
          "response": []
        },
        {
          "name": "Get All Venues",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/venues",
              "host": ["{{baseUrl}}"],
              "path": ["api", "venues"]
            },
            "description": "Get all venues (public endpoint)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Rate Limiting Tests",
      "item": [
        {
          "name": "Test Rate Limit - Multiple Login Attempts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Test rate limiting by making multiple failed login attempts"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string",
      "description": "JWT token obtained from login endpoint"
    }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Test for successful authentication",
          "pm.test(\"Status code is 200\", function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "// Test for JWT token in response",
          "pm.test(\"Response has JWT token\", function () {",
          "    var jsonData = pm.response.json();",
          "    pm.expect(jsonData.accessToken).to.exist;",
          "    pm.expect(jsonData.tokenType).to.equal(\"Bearer\");",
          "    pm.expect(jsonData.user).to.exist;",
          "    pm.expect(jsonData.user.username).to.exist;",
          "    pm.expect(jsonData.user.role).to.exist;",
          "});",
          "",
          "// Store JWT token for subsequent requests",
          "if (pm.response.code === 200) {",
          "    var jsonData = pm.response.json();",
          "    pm.collectionVariables.set(\"jwt_token\", jsonData.accessToken);",
          "}"
        ]
      }
    }
  ],
  "auth": null
}